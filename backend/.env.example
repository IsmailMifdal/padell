# Copier ce fichier vers .env et adapter les valeurs
DATABASE_URL="postgresql://padel:padel_dev_password@localhost:5433/padel?schema=public"
REDIS_URL="redis://localhost:6379"

# Générer un secret fort en production : openssl rand -hex 64
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# Passerelle CMI (test : https://testpayment.cmi.co.ma)
CMI_GATEWAY_URL="https://testpayment.cmi.co.ma/fim/est3Dgate"
CMI_MERCHANT_ID="600000000"
CMI_STORE_KEY="TEST1234"
CMI_OK_URL="https://api.example.ma/v1/payments/cmi/ok"
CMI_FAIL_URL="https://api.example.ma/v1/payments/cmi/fail"
CMI_CALLBACK_URL="https://api.example.ma/v1/payments/cmi/callback"

# Auth sociale (id_token vérifiés côté serveur)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
APPLE_CLIENT_ID="ma.padel.app"

PORT=3000
NODE_ENV=development
