# Copier ce fichier vers .env et adapter les valeurs
DATABASE_URL="postgresql://padel:padel_dev_password@localhost:5433/padel?schema=public"
REDIS_URL="redis://localhost:6379"

# Générer un secret fort en production : openssl rand -hex 64
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# Passerelle CMI (test : https://testpayment.cmi.co.ma)
CMI_GATEWAY_URL="https://testpayment.cmi.co.ma/fim/est3Dgate"
CMI_MERCHANT_ID="600000000"
CMI_STORE_KEY="TEST1234"
CMI_OK_URL="https://api.example.ma/v1/payments/cmi/ok"
CMI_FAIL_URL="https://api.example.ma/v1/payments/cmi/fail"
CMI_CALLBACK_URL="https://api.example.ma/v1/payments/cmi/callback"

# Auth sociale (id_token vérifiés côté serveur)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
APPLE_CLIENT_ID="ma.padel.app"

# SMS OTP — Twilio (console.twilio.com). Sans ces clés : code loggé (dev)
# TWILIO_ACCOUNT_SID="ACxxxxxxxx"
# TWILIO_AUTH_TOKEN="xxxxxxxx"
# TWILIO_FROM="+1xxxxxxxxxx"

# Push FCM — JSON du compte de service Firebase encodé en base64
# (Console Firebase > Paramètres > Comptes de service > Générer une clé)
# FIREBASE_SERVICE_ACCOUNT_BASE64="eyJ0eXBlIjoi..."

# Emails transactionnels — Brevo (app.brevo.com > SMTP & API). Sans clé : loggé
# BREVO_API_KEY="xkeysib-..."
# EMAIL_FROM="no-reply@padel.ma"
# EMAIL_FROM_NAME="Padel"

# Stockage médias — S3 ou Cloudflare R2 (S3_ENDPOINT requis pour R2/MinIO)
# S3_BUCKET="padel-media"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_REGION="auto"
# S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# S3_PUBLIC_URL="https://media.padel.ma"

# Crash reporting — Sentry (sentry.io). Sans DSN : inactif
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

PORT=3000
NODE_ENV=development
